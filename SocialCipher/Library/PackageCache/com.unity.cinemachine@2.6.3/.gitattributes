# Auto detect text files and perform LF normalization
* text=auto
*.unity text eol=lf
*.prefab text eol=lf
*.meta text eol=lf
*.json text eol=lf
*.asset text eol=lf
*.dwlt text eol=lf


# Custom for Visual Studio
*.cs     eol=lf

# Standard to msysgit
*.doc	 diff=astextplain
*.DOC	 diff=astextplain
*.docx diff=astextplain
*.DOCX diff=astextplain
*.dot  diff=astextplain
*.DOT  diff=astextplain
*.pdf  diff=astextplain
*.PDF	 diff=astextplain
*.rtf	 diff=astextplain
*.RTF	 diff=astextplain
